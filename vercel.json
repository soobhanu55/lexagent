{
  "version": 2,
  "functions": {
    "backend_api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/backend-api/(.*)",
      "destination": "/backend_api/index.py"
    },
    {
      "source": "/backend-api",
      "destination": "/backend_api/index.py"
    }
  ],
  "headers": [
    {
      "source": "/backend-api/chat",
      "headers": [
        {
          "key": "X-Accel-Buffering",
          "value": "no"
        },
        {
          "key": "Content-Type",
          "value": "text/event-stream"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Connection",
          "value": "keep-alive"
        }
      ]
    }
  ]
}
